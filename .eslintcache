rop-types\";\nimport _ from \"lodash\";\n\nconst Pagination = ({ itemsCount, pageSize, currentPage, onPageChange }) => {\n  const pagesCount = Math.ceil(itemsCount / pageSize);\n  if (pagesCount === 1) return null;\n  const pages = _.range(1, pagesCount + 1);\n\n  return (\n    <nav>\n      <ul className=\"pagination\">\n        {pages.map(page => (\n          <li\n            key={page}\n            className={page === currentPage ? \"page-item active\" : \"page-item\"}\n          >\n            <a className=\"page-link\" onClick={() => onPageChange(page)}>\n              {page}\n            </a>\n          </li>\n        ))}\n      </ul>\n    </nav>\n  );\n};\n\nPagination.propTypes = {\n  itemsCount: PropTypes.number.isRequired,\n  pageSize: PropTypes.number.isRequired,\n  currentPage: PropTypes.number.isRequired,\n  onPageChange: PropTypes.func.isRequired\n};\n\nexport default Pagination;\n","/Users/darlevy/WebstormProjects/vidly/src/utils/paginate.js",[],"/Users/darlevy/WebstormProjects/vidly/src/components/moviesTable.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/listGroup.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/table.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/tableHeader.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/tableBody.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/rentals.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/navBar.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/customers.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/notFound.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/movieForm.jsx",[],{"ruleId":"83","replacedBy":"84"},{"ruleId":"85","replacedBy":"86"},{"ruleId":"87","severity":1,"message":"88","line":18,"column":13,"nodeType":"89","endLine":18,"endColumn":73},"no-native-reassign",["90"],"no-negated-in-lhs",["91"],"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-global-assign","no-unsafe-negation"]