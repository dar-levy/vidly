ervices/fakeGenreService.js",[],"/Users/darlevy/WebstormProjects/vidly/src/registerServiceWorker.js",[],"/Users/darlevy/WebstormProjects/vidly/src/components/movies.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/like.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/pagination.jsx",["60"],"import React from \"react\";\nimport _ from \"lodash\";\n\nconst Pagination = (props) => {\n  const { totalCount, pageSize } = props;\n  const pagesCount = Math.ceil(totalCount / pageSize);\n  if (pagesCount === 1) return null;\n  const pages = _.range(1, pagesCount + 1);\n\n  return (\n    <nav aria-label=\"Page navigation example\">\n      <ul className=\"pagination\">\n        {pages.map((page) => (\n          <li key={page} className=\"page-item\">\n            <a className=\"page-link\">{page}</a>\n          </li>\n        ))}\n      </ul>\n    </nav>\n  );\n};\n\nexport default Pagination;\n",["61","62"],"/Users/darlevy/WebstormProjects/vidly/src/utils/paginate.js",[],"/Users/darlevy/WebstormProjects/vidly/src/components/moviesTable.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/listGroup.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/table.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/tableHeader.jsx",[],"/Users/darlevy/WebstormProjects/vidly/src/components/common/tableBody.jsx",[],{"ruleId":"63","severity":1,"message":"64","line":18,"column":13,"nodeType":"65","endLine":18,"endColumn":73},{"ruleId":"66","replacedBy":"67"},{"ruleId":"68","replacedBy":"69"},"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-native